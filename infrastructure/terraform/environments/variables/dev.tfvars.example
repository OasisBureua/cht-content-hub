# Content Hub — dev.tfvars.example
# Copy: cp dev.tfvars.example dev.tfvars
# See README.md in this folder for full setup steps.

project     = "contenthub"
environment = "dev"
deploy_mode = "cht-vpc"

api_domain          = "devhub.communityhealth.media"
acm_certificate_arn = ""

# From cht-platform-tool Terraform outputs (shared VPC; own contenthub-dev-cluster)
vpc_id = "vpc-xxxxxxxx"
private_subnet_ids = ["subnet-aaaaaaaa", "subnet-bbbbbbbb"]
public_subnet_ids  = ["subnet-cccccccc", "subnet-dddddddd"]

# CHT dev backend ECS SG — terraform output backend_security_group_id (cht-platform-tool us-east-1)
cht_backend_security_group_id = "sg-xxxxxxxx"
# CHT dev NAT egress — terraform output nat_gateway_public_ips (or bare IPs; /32 added automatically)
cht_nat_gateway_cidr_blocks = [
  "18.233.236.119/32",
  "44.223.243.240/32",
]
alb_allow_public_ingress      = false
enable_waf                    = true

api_image = "ACCOUNT.dkr.ecr.us-east-1.amazonaws.com/contenthub-dev-api:1.0.0"

rds_instance_class    = "db.t4g.small"
rds_engine_version    = "15.17"
rds_allocated_storage = 20
rds_multi_az          = false
rds_backup_retention  = 7
log_retention_days    = 7

api_task_cpu      = 512
api_task_memory   = 1024
api_desired_count = 1
api_min_capacity  = 1
api_max_capacity  = 4

worker_task_cpu      = 512
worker_task_memory   = 1024
worker_desired_count = 0

# Sync Lambdas — build artifact first: ./scripts/build-sync-lambda.sh
# Disabled by default on dev until HCP intel handlers are complete (Option A).
sync_jobs_enabled = {
  cache_clear         = false
  hcp_intel_poll      = false
  openalex_backfill   = false
  kol_hcp_matcher     = false
  post_tagging        = false
  playlist_doctor_tagger = false
}
# sync_lambda_package_path = "/absolute/path/to/dist/sync-lambda.zip"

cht_cache_clear_url = "https://devapp.communityhealth.media/api/internal/cache/catalog/clear"

# ── Secrets (do NOT commit — use TF_VAR_* or GitHub Environment secrets) ─────
# Core (required):
# public_api_key        = ""
# webhook_api_key       = ""
# jwt_secret            = ""
# internal_cache_secret = ""
#
# Platform integrations (optional — for LinkedIn/YouTube sync + AI insights):
# linkedin_ads_client_id     = ""
# linkedin_ads_client_secret = ""
# linkedin_ads_access_token  = ""   # OAuth token — or PATCH integration accessToken
# linkedin_ad_account_id     = ""
# linkedin_client_id         = ""
# linkedin_client_secret     = ""
# linkedin_redirect_uri      = ""
# linkedin_scopes            = ""
# linkedin_org_urn           = ""
# youtube_api_key            = ""
# youtube_channel_id         = ""
# youtube_channel_handle     = ""
# openai_api_key             = ""
# anthropic_api_key          = ""
# x_bearer_token             = ""
# x_account_handle           = ""
# wordpress_webhook_secret   = ""
#
# Or export TF_VAR_<name> instead of inline values above.
# GitHub Actions: see .github/CI_CD.md (Environment "development")
# CI uses dev.github.tfvars + TF_VAR_* secrets (no secrets in repo)
