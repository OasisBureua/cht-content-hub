# Content Hub — prod.tfvars.example
# Copy: cp prod.tfvars.example prod.tfvars
#
# Non-secret prod infra is in prod.github.tfvars (committed). Local scripts and CI load:
#   1. prod.github.tfvars  — always
#   2. prod.tfvars         — if present (secrets + overrides; wins on duplicate keys)
#
# GitHub Actions prod deploy uses prod.github.tfvars + TF_VAR_* secrets (no prod.tfvars).

# ── Optional: only if arming failover via tfvars (prefer ./scripts/arm-route53-failover.sh) ──
# enable_route53_failover = true

# ── Secrets (required for local terraform apply) ─────────────────────────────
# public_api_key        = ""
# webhook_api_key       = ""
# jwt_secret            = ""
# internal_cache_secret = ""
#
# Platform integrations (optional):
# linkedin_ads_client_id     = ""
# linkedin_ads_client_secret = ""
# linkedin_ads_access_token  = ""
# linkedin_ad_account_id     = ""
# linkedin_client_id         = ""
# linkedin_client_secret     = ""
# linkedin_redirect_uri      = ""
# linkedin_scopes            = ""
# linkedin_org_urn           = ""
# youtube_api_key            = ""
# youtube_channel_id         = ""
# youtube_channel_handle     = ""
# openai_api_key             = ""
# anthropic_api_key          = ""
# x_bearer_token             = ""
# x_account_handle           = ""
# wordpress_webhook_secret   = ""
#
# Or export TF_VAR_<name> instead of inline values.
