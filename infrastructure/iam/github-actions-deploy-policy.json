{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDangerousIAM",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:DeleteUser",
        "iam:CreateAccessKey",
        "iam:DeleteAccessKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECRAuth",
      "Effect": "Allow",
      "Action": ["ecr:GetAuthorizationToken"],
      "Resource": "*"
    },
    {
      "Sid": "ECRPushPull",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:CompleteLayerUpload",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer",
        "ecr:DescribeRepositories",
        "ecr:ListImages",
        "ecr:CreateRepository"
      ],
      "Resource": "arn:aws:ecr:*:ACCOUNT_ID:repository/contenthub-*"
    },
    {
      "Sid": "TerraformState",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::cht-contenthub-terraform-state",
        "arn:aws:s3:::cht-contenthub-terraform-state/*"
      ]
    },
    {
      "Sid": "ContentHubDeploy",
      "Effect": "Allow",
      "Action": [
        "ecs:*",
        "elasticloadbalancing:*",
        "rds:*",
        "elasticache:*",
        "secretsmanager:*",
        "logs:*",
        "iam:PassRole",
        "iam:GetRole"
      ],
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "aws:ResourceTag/Project": "contenthub*"
        }
      }
    }
  ]
}
